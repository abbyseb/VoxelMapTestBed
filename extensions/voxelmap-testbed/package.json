{
  "name": "voxelmap-testbed",
  "displayName": "VoxelMap TestBed",
  "description": "Developer benchmark harness — Gold browser, experiments, results (mock mode for Phase 1)",
  "version": "0.1.0",
  "publisher": "voxelmap",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abbyseb/VoxelMapTestBed.git",
    "directory": "extensions/voxelmap-testbed"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/testbed-icon.svg",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "VoxelMap TestBed",
        "uiTheme": "vs-dark",
        "path": "./themes/voxelmap-testbed-color-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "voxelmap-testbed",
          "title": "VoxelMap TestBed",
          "icon": "resources/testbed-icon.svg"
        }
      ]
    },
    "views": {
      "voxelmap-testbed": [
        {
          "id": "vmtb.gold",
          "name": "Gold",
          "icon": "$(database)"
        },
        {
          "id": "vmtb.experiments",
          "name": "Experiments",
          "icon": "$(beaker)"
        },
        {
          "id": "vmtb.runs",
          "name": "Runs",
          "icon": "$(history)"
        },
        {
          "id": "vmtb.leaderboard",
          "name": "Leaderboard",
          "icon": "$(list-ordered)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vmtb.gold",
        "contents": "Browse Gold packs and scan checklist.\n[Verify Gold](command:vmtb.gold.verify)\n[Refresh](command:vmtb.gold.refresh)"
      },
      {
        "view": "vmtb.experiments",
        "contents": "Experiment YAML specs.\n[Run experiment (mock)](command:vmtb.experiment.run)\n[Edit preview](command:vmtb.experiment.edit)\n[Initialize workspace](command:vmtb.initWorkspace)\n[Refresh](command:vmtb.experiments.refresh)"
      },
      {
        "view": "vmtb.runs",
        "contents": "Train/test run outputs.\n[Refresh](command:vmtb.runs.refresh)\nClick **notes.md** under a run to open the notes panel."
      },
      {
        "view": "vmtb.leaderboard",
        "contents": "Compare runs vs baselines.\n[Refresh](command:vmtb.leaderboard.refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vmtb.gold.refresh",
          "when": "view == vmtb.gold",
          "group": "navigation"
        },
        {
          "command": "vmtb.gold.pickProfile",
          "when": "view == vmtb.gold",
          "group": "navigation"
        },
        {
          "command": "vmtb.gold.filterTags",
          "when": "view == vmtb.gold",
          "group": "navigation"
        },
        {
          "command": "vmtb.experiment.run",
          "when": "view == vmtb.experiments",
          "group": "navigation"
        },
        {
          "command": "vmtb.experiment.edit",
          "when": "view == vmtb.experiments",
          "group": "navigation"
        },
        {
          "command": "vmtb.experiments.refresh",
          "when": "view == vmtb.experiments",
          "group": "navigation"
        },
        {
          "command": "vmtb.runs.refresh",
          "when": "view == vmtb.runs",
          "group": "navigation"
        },
        {
          "command": "vmtb.leaderboard.refresh",
          "when": "view == vmtb.leaderboard",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "VoxelMap TestBed",
      "properties": {
        "vmtb.dataMode": {
          "type": "string",
          "enum": [
            "mock",
            "demo",
            "live"
          ],
          "default": "mock",
          "description": "mock = fixtures/ only; demo = DEMO cases + fixtures runs; live = backend (Phase 4+)"
        },
        "vmtb.demoPath": {
          "type": "string",
          "default": "",
          "description": "Folder with preprocessed DEMO cases (demo mode). e.g. /Volumes/T7 Shield/DENNIS_BACKUP/DEMO"
        },
        "vmtb.goldPath": {
          "type": "string",
          "default": "",
          "description": "Local folder containing spare-gold manifest and packs (live mode)"
        },
        "vmtb.fixturesPath": {
          "type": "string",
          "default": "",
          "description": "Override path to fixtures/ (mock mode). Empty = bundled workspace fixtures."
        },
        "vmtb.mockRunsWorkspace": {
          "type": "string",
          "default": "",
          "description": "Folder where mock runs/ are written. Empty = workspace folder or VoxelMapTestBed repo root."
        }
      }
    },
    "commands": [
      {
        "command": "vmtb.welcome.open",
        "title": "TestBed: Open Welcome",
        "icon": "$(home)"
      },
      {
        "command": "vmtb.gold.verify",
        "title": "TestBed: Verify Gold",
        "icon": "$(verified)"
      },
      {
        "command": "vmtb.gold.pickProfile",
        "title": "TestBed: Pick Gold Profile",
        "icon": "$(list-selection)"
      },
      {
        "command": "vmtb.notes.open",
        "title": "TestBed: Open Run Notes"
      },
      {
        "command": "vmtb.runs.openArtifact",
        "title": "TestBed: Open Run Artifact"
      },
      {
        "command": "vmtb.results.open",
        "title": "TestBed: Open Results Viewer",
        "icon": "$(graph)"
      },
      {
        "command": "vmtb.leaderboard.open",
        "title": "TestBed: Open Leaderboard",
        "icon": "$(list-ordered)"
      },
      {
        "command": "vmtb.train.open",
        "title": "TestBed: Open Train Monitor",
        "icon": "$(pulse)"
      },
      {
        "command": "vmtb.experiment.run",
        "title": "TestBed: Run Experiment (mock)",
        "icon": "$(play)"
      },
      {
        "command": "vmtb.experiment.edit",
        "title": "TestBed: Edit Experiment YAML",
        "icon": "$(edit)"
      },
      {
        "command": "vmtb.experiment.open",
        "title": "TestBed: Open Experiment File"
      },
      {
        "command": "vmtb.experiment.openPreview",
        "title": "TestBed: Open Experiment Preview"
      },
      {
        "command": "vmtb.gold.filterTags",
        "title": "TestBed: Filter Gold Tags",
        "icon": "$(filter)"
      },
      {
        "command": "vmtb.gold.clearTagFilter",
        "title": "TestBed: Clear Gold Tag Filter"
      },
      {
        "command": "vmtb.initWorkspace",
        "title": "TestBed: Initialize Workspace",
        "icon": "$(folder-opened)"
      },
      {
        "command": "vmtb.showOutput",
        "title": "TestBed: Show Output Channel"
      },
      {
        "command": "vmtb.gold.refresh",
        "title": "TestBed: Refresh Gold",
        "icon": "$(refresh)"
      },
      {
        "command": "vmtb.experiments.refresh",
        "title": "TestBed: Refresh Experiments",
        "icon": "$(refresh)"
      },
      {
        "command": "vmtb.runs.refresh",
        "title": "TestBed: Refresh Runs",
        "icon": "$(refresh)"
      },
      {
        "command": "vmtb.leaderboard.refresh",
        "title": "TestBed: Refresh Leaderboard",
        "icon": "$(refresh)"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js && node esbuild.webviews.js",
    "compile:webviews": "node esbuild.webviews.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  }
}
